{
  "expo": {
    "name": "ClubX",
    "slug": "clubx",
    "version": "1.0.0",
    "scheme": "clublms",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "releaseChannel": "dev"
    },
    "splash": {
      "image": "./assets/splash-native.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clubx.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan barcodes for event check-in",
        "LSApplicationQueriesSchemes": ["supertoss", "kakaopay"]
      }
    },
    "android": {
      "package": "com.clubx.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": ["./src/assets/fonts/porter-sans-inline-block.ttf"]
        }
      ],
      "./plugins/withNaverMap",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan barcodes for event check-in"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Camera is used to scan barcodes for event check-in"
        }
      ]
    ]
  }
}
