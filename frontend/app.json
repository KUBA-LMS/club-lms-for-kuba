{
  "expo": {
    "name": "Club LMS",
    "slug": "club-lms",
    "version": "1.0.0",
    "scheme": "clublms",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "apiUrl": "http://localhost:8002/api/v1",
      "releaseChannel": "dev"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kuba.clublms",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan barcodes for event check-in",
        "LSApplicationQueriesSchemes": ["supertoss", "kakaopay"]
      }
    },
    "android": {
      "package": "com.kuba.clublms",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": ["./src/assets/fonts/porter-sans-inline-block.ttf"]
        }
      ],
      "./plugins/withNaverMap",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan barcodes for event check-in"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Camera is used to scan barcodes for event check-in"
        }
      ]
    ]
  }
}
