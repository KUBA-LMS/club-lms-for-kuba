{
  "expo": {
    "name": "ClubX",
    "slug": "clubx",
    "version": "1.1.0",
    "scheme": "clublms",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "releaseChannel": "dev",
      "eas": {
        "projectId": "59c3694a-212d-4365-ada3-56408e9e7189"
      }
    },
    "splash": {
      "image": "./assets/splash-native.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clubx.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to show nearby club events on the map — for example, displaying meetups happening within 2 km of you — and to sort the event list by distance so the closest ones appear first.",
        "NSCameraUsageDescription": "Camera is used to scan QR codes for event check-in and group invitations.",
        "LSApplicationQueriesSchemes": [
          "supertoss",
          "kakaopay",
          "supertoss",
          "kakaopay"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.clubx.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/porter-sans-inline-block.ttf"
          ]
        }
      ],
      "./plugins/withNaverMap",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan barcodes for event check-in"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Camera is used to scan barcodes for event check-in"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000000"
        }
      ]
    ]
  }
}
